{
  "name": "visit-signin",
  "version": "0.1.0",
  "private": false,
  "description": "Visitor sign-in kiosk for aerospace / CMMC-adjacent shops. Runs on Cloudflare Workers, prints AirPrint badges, notifies hosts in Slack.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ffmfg/visit-signin.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:migrate:local": "wrangler d1 migrations apply visit_signin --local",
    "db:migrate:remote": "wrangler d1 migrations apply visit_signin --remote"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "zod": "^3.23.8",
    "pdf-lib": "^1.17.1",
    "@fontsource/inter": "^5.1.0",
    "ulid": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20241218.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}
