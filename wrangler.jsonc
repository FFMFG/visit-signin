{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "visit-signin",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],

  "rules": [
    { "type": "Text", "globs": ["**/*.md"], "fallthrough": true }
  ],

  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "visit_signin",
      "database_id": "28a37592-0ba3-4dd2-9cb2-1ebfab7496da",
      "migrations_dir": "src/worker/migrations"
    }
  ],

  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "visit-signin-artifacts"
    }
  ],

  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "c1f3f323b07e41fa90e000982e754209"
    }
  ],

  "triggers": {
    "crons": ["7 0 * * *"]
  },

  "vars": {
    "TIMEZONE": "America/Denver",
    "AUTO_SIGNOUT_HOUR_LOCAL": "18",
    "FRONT_DESK_CHANNEL": "#front-desk",
    "COMPLIANCE_CHANNEL": "#compliance",
    "ERROR_CHANNEL": "#visitor-app-errors"
  },

  "observability": {
    "enabled": true
  }
}
